#                               -----AI-------
#▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓
def zrcadli(matice):
    # Horizontální překlopení (každý řádek se otočí)
    return [radek[::-1] for radek in matice]

def rotuj_doprava(matice):
    # Otočí matici o 90 stupňů doprava
    return [list(radek) for radek in zip(*matice[::-1])]

def otoc_zpet(matice, uhel):
    # Otočí matici zpět do původní polohy
    nova = matice
    if uhel == 90:
        # Otočit 3x doprava = 1x doleva (zpět na začátek)
        for _ in range(3): nova = rotuj_doprava(nova)
    elif uhel == 180:
        for _ in range(2): nova = rotuj_doprava(nova)
    elif uhel == 270:
        for _ in range(1): nova = rotuj_doprava(nova)
    return nova
#▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓

def solve():
        sudoku = []
        for y in range(9):
                radek = []
                for x in range(9):
                        hodnota = sudokug[y][x].get()  # Přečte text z políčka
                        if hodnota == "" or not hodnota.isdigit():
                                radek.append(0)  # Prázdné políčko nebo blbost = 0
                        else:
                                radek.append(int(hodnota))  # Číslo převede na int
                sudoku.append(radek)

        #                               -----AI-------
        # ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓
        a = time.time()
        output = []

        def vnitrni_vlakno(uhel, zrcadlit_data):
            # 1. Příprava dat
            data = [radek[:] for radek in sudoku]  # Kopie

            if zrcadlit_data:
                data = zrcadli(data)

            if uhel == 90:
                data = rotuj_doprava(data)
            elif uhel == 180:
                data = rotuj_doprava(rotuj_doprava(data))
            elif uhel == 270:
                data = rotuj_doprava(rotuj_doprava(rotuj_doprava(data)))

            # 2. Výpočet
            solver = SudokuSolver(data)
            reseni = solver.solve(output)

            # 3. Zpracování výsledku zpět
            if reseni and not output:
                temp_res = otoc_zpet(reseni, uhel)
                if zrcadlit_data:
                    temp_res = zrcadli(temp_res)

                # Finální zápis (pokud nás někdo nepředběhl)
                if not output:
                    output.append(temp_res)
                    print(f"Vyhrálo vlákno: uhel {uhel}, zrcadlení: {zrcadlit_data}")
                    print(f"Čas: {time.time() - a}s")

        # Spuštění 8 vláken (4 normální, 4 zrcadlené)
        for zrcadlit in [False, True]:
            for uhel in [0, 90, 180, 270]:
                t = threading.Thread(target=vnitrni_vlakno, args=(uhel, zrcadlit))
                t.daemon = True
                t.start()

        # 4. KONTROLA VÝSLEDKU (Semaforu)
        def zkontroluj_semafor():
            if output:
                finalni_sudoku = output[0]
                for y in range(9):
                    for x in range(9):
                        # Pokud je políčko prázdné (uživatel tam nic nepsal), doplníme výsledek
                        if sudokug[y][x].get() == "":
                            # Musíš pracovat s tím, že výsledek může být [n] nebo n
                            cislo = finalni_sudoku[y][x]
                            if isinstance(cislo, list):
                                cislo = cislo[0]

                            sudokug[y][x].insert(0, str(cislo))
                            sudokug[y][x].config(fg="blue")  # Modr
            else:
                # Pokud ještě není hotovo, zkus to znovu za 100ms
                root.after(100, zkontroluj_semafor)

        zkontroluj_semafor()
        # ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓



